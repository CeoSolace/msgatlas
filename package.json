{
  "name": "private-messaging-platform",
  "version": "1.0.0",
  "description": "Full-stack private messaging platform built with Fastify, Socket.IO, MongoDB, React and Vite.",
  "type": "commonjs",
  "main": "dist/index.js",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"node --loader ts-node/esm src/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/cookie": "^8.8.0",
    "@fastify/helmet": "^10.0.0",
    "@fastify/cors": "^8.4.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "argon2": "^0.30.4",
    "cloudinary": "^2.5.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.18.0",
    "ioredis": "^5.4.1",
    "libsodium-wrappers": "^0.7.10",
    "mongoose": "^8.0.0",
    "pino": "^8.17.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "zod": "^3.22.4",
    "lru-cache": "^10.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.4.2",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^4.3.9",
    "concurrently": "^8.2.0"
  }
}
